# MCSS backend configuration (see src/config.rs).

# Core
DATABASE_URL=postgres://localhost/mcss
JWT_SECRET=change-me-to-a-long-random-secret
PORT=3000
ENVIRONMENT=development            # development | production

# Credential encryption at rest (32 bytes, hex or base64). Without it,
# channel secrets are stored unprotected with a warning.
ENCRYPTION_KEY=

# Separate HMAC secret for signing/verifying file download URLs (review #8).
# When unset, falls back to JWT_SECRET for backward compatibility — existing
# signed URLs remain valid. Set this to rotate file-URL signing independently
# of the auth secret.
# FILE_SIGNING_SECRET=

# Deployment origins (required in production for CORS + signed URLs)
FRONTEND_URL=
BACKEND_URL=
PUBLIC_STORAGE_URL=
EXTRA_ORIGINS=                     # comma-separated additional origins

# File storage
UPLOAD_DIR=data/uploads

# LINE platform
LINE_CHANNEL_SECRET=               # webhook signature verification
LINE_CHANNEL_ACCESS_TOKEN=         # outbound push / LIFF welcome flow
LINE_BOT_ID=                       # e.g. @support
LIFF_ID=                           # LINE front-end app identifier

# Facebook platform
FACEBOOK_APP_SECRET=               # webhook signature verification
FACEBOOK_VERIFY_TOKEN=             # subscription handshake

# System-to-system gate
SYSTEM_API_KEY=

# Alerting destinations (each optional; missing config fails gracefully)
ALERT_EMAIL_API_KEY=
ALERT_EMAIL_MIN_SEVERITY=high
ALERT_CHAT_WEBHOOK_URL=
ALERT_CHAT_MIN_SEVERITY=medium
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_MIN_SEVERITY=low

# Installer service
INSTALLER_PORT=8976
CLOUD_OAUTH_CLIENT_ID=
