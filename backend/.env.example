# Multi-Channel Customer Support System — backend environment settings.
# Copy to .env and fill in real values; every variable is optional in
# development unless noted.

# SQLite database location.
DATABASE_URL=sqlite://data/mcss.db?mode=rwc

# Access/refresh token signing secret. REQUIRED in production.
JWT_SECRET=change-me

# Credential protection key (CRD 5716-5727): the STANDARD-BASE64 ENCODING OF
# EXACTLY 32 RANDOM BYTES, used for AES-256-GCM encryption of stored channel
# integration credentials. When unset, newly stored credentials are kept as
# plaintext and a warning is logged; previously encrypted values then become
# unreadable (documented "not configured" error).
# Generate one with:  openssl rand -base64 32
ENCRYPTION_KEY=

# development | production
ENVIRONMENT=development

# Public URLs (used for CORS allow-list and webhook URL derivation).
FRONTEND_URL=
BACKEND_URL=
PUBLIC_STORAGE_URL=
EXTRA_ORIGINS=

# HTTP listen port.
PORT=3000

# Message-attachment upload directory.
UPLOAD_DIR=data/uploads

# System-to-system API key (X-System-Key header gate).
SYSTEM_API_KEY=

# --- Inbound webhook signature secrets (CRD §4.2) ---

# LINE channel secret: HMAC-SHA256 key for the x-line-signature header on
# POST /api/webhook. Missing -> webhook deliveries are rejected with 401.
LINE_CHANNEL_SECRET=

# Facebook/Instagram app secret: HMAC-SHA256 key for the x-hub-signature-256
# header on /api/webhooks/facebook. Two names accepted, in priority order:
FACEBOOK_APP_SECRET=
FB_APP_SECRET=

# Verification token echoed during the Facebook subscription handshake
# (GET /api/webhooks/facebook?hub.mode=subscribe&...).
FACEBOOK_VERIFY_TOKEN=
